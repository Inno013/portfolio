# ============================================================
# Notion Integration
# ============================================================
# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs (get from your Notion database page URL)
# URL format: https://notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_PROFILE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SKILLS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PROJECTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_EXPERIENCE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_EDUCATION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Contact Form (Formspree)
# ============================================================
# Sign up free at https://formspree.io → create form → copy the form ID
# Example: if your form URL is https://formspree.io/f/xabcdefg, set: xabcdefg
FORMSPREE_ID=xabcdefg
