---
const testimonials = [
  {
    name: "Sarah Chen",
    role: "VP of Operations",
    company: "TechFlow Inc.",
    content:
      "StreamLine transformed our entire workflow. We've reduced manual tasks by 80% and our team is more productive than ever.",
    rating: 5,
    avatar: "/professional-woman-headshot.png",
  },
  {
    name: "Marcus Rodriguez",
    role: "CTO",
    company: "DataSync Solutions",
    content:
      "The AI automation is incredible. What used to take hours now happens in minutes. ROI was evident within the first month.",
    rating: 5,
    avatar: "/professional-man-headshot.png",
  },
  {
    name: "Emily Watson",
    role: "Project Manager",
    company: "InnovateLab",
    content:
      "Best investment we've made. The analytics dashboard gives us insights we never had before. Highly recommend!",
    rating: 5,
    avatar: "/avatar-1.png",
  },
]

const generateStars = (rating: number) => {
  return Array.from({ length: rating }, (_, i) => `
    <svg key="${i}" class="h-5 w-5 fill-primary text-primary" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  `).join('')
}
---

<section id="testimonials" class="py-20 px-4 sm:px-6 lg:px-8 bg-card/50">
  <div class="container mx-auto">
    <div class="text-center space-y-4 mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold">
        Trusted by
        <span class="text-primary block">Industry Leaders</span>
      </h2>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
        See what our customers are saying about StreamLine
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <div
          class="rounded-lg border bg-background text-card-foreground shadow-sm border-border hover:border-primary/50 transition-all duration-300"
        >
          <div class="p-6">
            <div class="space-y-4">
              <!-- Rating -->
              <div class="flex space-x-1">
                <Fragment set:html={generateStars(testimonial.rating)} />
              </div>

              <!-- Content -->
              <p class="text-foreground leading-relaxed">"{testimonial.content}"</p>

              <!-- Author -->
              <div class="flex items-center space-x-3 pt-4 border-t border-border">
                <img
                  src={testimonial.avatar || "/placeholder.svg"}
                  alt={testimonial.name}
                  class="w-12 h-12 rounded-full"
                />
                <div>
                  <div class="font-semibold text-foreground">{testimonial.name}</div>
                  <div class="text-sm text-muted-foreground">
                    {testimonial.role} at {testimonial.company}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>