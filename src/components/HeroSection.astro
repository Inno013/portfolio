---
import type { Profile } from "../types/index";

export interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const { name, greeting, role, description, cvUrl, profileImage, socialLinks } = profile;
---

<section
  id="hero-section"
  class="hero-section relative min-h-screen overflow-hidden flex items-center"
>
  <!-- Grid overlay -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(64,205,121,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(64,205,121,0.03)_1px,transparent_1px)] bg-[size:64px_64px] pointer-events-none"></div>

  <!-- Animated background blobs -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-pr-green/8 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 left-1/4 w-64 h-64 bg-pr-green/5 rounded-full blur-3xl" style="animation: float 8s ease-in-out infinite reverse;"></div>
    <div class="absolute top-20 right-20 w-1 h-1 bg-pr-green rounded-full opacity-60 animate-ping" style="animation-delay:0.5s"></div>
    <div class="absolute top-40 right-40 w-1.5 h-1.5 bg-pr-green/60 rounded-full animate-pulse" style="animation-delay:1s"></div>
    <div class="absolute bottom-40 right-32 w-6 h-6 border border-pr-green/30 rounded-full animate-spin" style="animation-duration:12s"></div>
    <div class="absolute top-16 right-32 w-8 h-8 border border-pr-green/20 rounded animate-pulse" style="animation-delay:1.5s; transform:rotate(45deg)"></div>
  </div>

  <!-- Main Content -->
  <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left Content -->
      <div class="space-y-8 order-2 lg:order-1 animate-fade-in-up">
        <!-- Greeting badge -->
        <div class="inline-flex items-center gap-2 bg-pr-green/10 dark:bg-pr-magenta/10 border border-pr-green/25 dark:border-pr-magenta/25 text-pr-green dark:text-pr-magenta rounded-full px-4 py-1.5 text-sm font-medium">
          <span class="w-1.5 h-1.5 bg-pr-green rounded-full animate-pulse"></span>
          {greeting}
        </div>

        <!-- Name -->
        <div class="space-y-3">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-foreground leading-tight">
            I'm <span class="text-pr-green dark:text-pr-magenta gradient-text">{name}</span>
          </h1>
          <p class="text-xl text-foreground/60 font-light">{role}</p>
          <div class="w-20 h-0.5 bg-gradient-to-r from-pr-green to-transparent"></div>
        </div>

        <!-- Description -->
        <p class="text-foreground/55 text-base leading-relaxed max-w-xl">{description}</p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={cvUrl}
            download
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-pr-green hover:bg-sr-green text-pr-black font-semibold rounded-xl transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-pr-green/30 group"
          >
            <svg class="w-4 h-4 group-hover:translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download CV
          </a>
          <a
            href="#portfolio"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-foreground/20 hover:border-pr-green/60 dark:hover:border-pr-magenta/60 text-foreground hover:text-pr-green dark:hover:text-pr-magenta font-medium rounded-xl transition-all duration-300 hover:scale-105 hover:bg-pr-green/5 dark:hover:bg-pr-magenta/5"
          >
            View Portfolio
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Social Links -->
        <div>
          <p class="text-foreground/35 text-xs font-medium tracking-widest uppercase mb-4">Find Me On</p>
          <div class="flex gap-3">
            {socialLinks.github && (
              <a href={socialLinks.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-link">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              </a>
            )}
            {socialLinks.linkedin && (
              <a href={socialLinks.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-link">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            )}
            {socialLinks.instagram && (
              <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            )}
            {socialLinks.facebook && (
              <a href={socialLinks.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            )}
            {socialLinks.whatsapp && (
              <a href={socialLinks.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="social-link">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.085"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Right - Profile Image -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end animate-fade-in-up" style="animation-delay:0.3s">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-pr-green/20 to-transparent rounded-full blur-3xl scale-110 animate-pulse-glow"></div>
          <div class="relative w-72 h-72 md:w-80 md:h-80 lg:w-[26rem] lg:h-[26rem]">
            <!-- Spinning border -->
            <div class="absolute inset-0 rounded-full p-px animate-spin" style="animation-duration:15s; background: conic-gradient(from 0deg, #40cd79, transparent, transparent, #40cd79);">
              <div class="w-full h-full bg-pr-black rounded-full"></div>
            </div>
            <!-- Profile image -->
            <div class="absolute inset-3 rounded-full overflow-hidden ring-1 ring-pr-green/20">
              <img
                src={profileImage}
                alt={`${name} - ${role}`}
                class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-700"
                loading="eager"
              />
            </div>
            <!-- Role badge -->
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 bg-sr-black dark:bg-pr-green/8 border border-pr-green/30 dark:border-pr-magenta/30 text-foreground text-xs font-medium px-4 py-2 rounded-full whitespace-nowrap shadow-lg shadow-pr-green/10">
              <span class="text-pr-green dark:text-pr-magenta">✦ </span>{role}
            </div>
            <!-- Floating dots -->
            <div class="absolute -top-2 -right-2 w-4 h-4 bg-pr-green rounded-full animate-bounce" style="animation-delay:0.8s"></div>
            <div class="absolute top-1/4 -left-4 w-2.5 h-2.5 border border-pr-green/60 rounded-full animate-ping" style="animation-delay:1.5s"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-foreground/30 animate-bounce">
      <span class="text-[10px] tracking-widest uppercase font-medium">Scroll</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0);    }
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }
  .gradient-text {
    background: linear-gradient(-45deg, #40cd79, #74dfa0, #5ad68c, #40cd79);
    background-size: 300% 300%;
    animation: gradient-shift 5s ease infinite;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  :global(.dark) .gradient-text {
    background: linear-gradient(-45deg, #be0267, #bf3286, #be0267, #bf3286);
    background-size: 300% 300%;
    animation: gradient-shift 5s ease infinite;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  @keyframes gradient-shift {
    0%   { background-position: 0% 50%;   }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%;   }
  }
  .social-link {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--foreground) 10%, transparent);
    color: color-mix(in srgb, var(--foreground) 40%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .social-link:hover {
    color: #40cd79;
    border-color: rgba(64,205,121,0.5);
    background: rgba(64,205,121,0.08);
    transform: scale(1.1);
  }
  :global(.dark) .social-link:hover {
    color: #be0267;
    border-color: rgba(190,2,103,0.5);
    background: rgba(190,2,103,0.08);
  }
</style>
