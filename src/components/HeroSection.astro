---
import ProfileImage from "../assets/profile.jpg";

export interface Props {
  greeting?: string;
  name?: string;
  role?: string;
  description?: string;
  cvUrl?: string;
  profileImage?: string;
  socialLinks?: {
    facebook?: string;
    instagram?: string;
    whatsapp?: string;
    linkedin?: string;
  };
}

const {
  greeting = "Hello Buds",
  name = "Dimas Ardiansyah",
  role = "UI / UX Design Enthusiast",
  description = "I'm a person who has a keen interest in the design layout. I think presenting an attractive design is a matter of concern in developing a branding of products. To creates a good design, I focus on proper composition and visual decoration details in order to make it more professional. For the time being, I'm developing the skill for acquiring the UI/UX design for dynamic application and web development.",
  cvUrl = "/cv/resume.pdf",
  profileImage = ProfileImage.src,
  socialLinks = {
    facebook: "https://facebook.com/username",
    instagram: "https://instagram.com/username",
    whatsapp: "https://wa.me/628123456789",
    linkedin: "https://linkedin.com/in/username",
  },
} = Astro.props;
---

<section id="hero-section" class="hero-section relative min-h-screen overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0">
    <!-- Gradient Background -->
    <!-- <div
      class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-800 to-black"
    >
    </div> -->

    <!-- Animated Background Elements -->
    <div
      class="absolute top-20 right-20 w-32 h-32 bg-green-500/20 rounded-full blur-xl animate-pulse"
    >
    </div>
    <div
      class="absolute top-40 right-40 w-6 h-6 bg-green-400 rounded-full animate-bounce"
      style="animation-delay: 0.5s;"
    >
    </div>
    <div
      class="absolute top-32 right-60 w-4 h-4 border-2 border-green-400 rounded-full animate-ping"
      style="animation-delay: 1s;"
    >
    </div>
    <div
      class="absolute bottom-40 right-32 w-8 h-8 border-2 border-purple-400 rounded-full animate-spin"
      style="animation-duration: 8s;"
    >
    </div>
    <div
      class="absolute top-60 right-16 w-2 h-2 bg-purple-400 rounded-full animate-pulse"
      style="animation-delay: 2s;"
    >
    </div>

    <!-- Plus Icon -->
    <div
      class="absolute top-16 right-32 text-green-400 animate-pulse"
      style="animation-delay: 1.5s;"
    >
      <svg
        class="w-8 h-8"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
    </div>

    <!-- Circle Elements -->
    <div
      class="absolute bottom-32 right-48 w-12 h-12 border-2 border-green-400 rounded-full opacity-60 animate-spin"
      style="animation-duration: 12s;"
    >
    </div>
  </div>

  <!-- Main Content -->
  <div
    class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 h-screen flex items-center"
  >
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center w-full">
      <!-- Left Content -->
      <div class="space-y-8 order-2 lg:order-1">
        <!-- Greeting -->
        <div class="space-y-4">
          <p
            class="text-white/80 text-lg font-light tracking-wide animate-fade-in-up"
          >
            {greeting}
          </p>

          <!-- Name with Highlight -->
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight animate-fade-in-up"
            style="animation-delay: 0.2s;"
          >
            I am <span class="text-green-400 gradient-text">{name}</span>
          </h1>

          <!-- Role -->
          <p
            class="text-white/70 text-xl font-light animate-fade-in-up"
            style="animation-delay: 0.4s;"
          >
            {role}
          </p>

          <!-- Decorative Line -->
          <div
            class="w-16 h-px bg-gradient-to-r from-green-400 to-transparent animate-fade-in-up"
            style="animation-delay: 0.6s;"
          >
          </div>
        </div>

        <!-- Description -->
        <div class="animate-fade-in-up" style="animation-delay: 0.8s;">
          <p class="text-white/60 text-base leading-relaxed max-w-2xl">
            {description}
          </p>
        </div>

        <!-- Action Buttons -->
        <div
          class="flex flex-col sm:flex-row gap-4 animate-fade-in-up"
          style="animation-delay: 1s;"
        >
          <a
            href={cvUrl}
            download
            class="inline-flex items-center px-6 py-3 bg-green-500 hover:bg-green-600 text-white font-medium rounded-lg transition-all duration-300 transform hover:scale-105 hover:shadow-lg group"
          >
            <svg
              class="w-5 h-5 mr-2 group-hover:animate-bounce"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            Download CV
          </a>

          <button
            class="inline-flex items-center px-6 py-3 border-2 border-white/30 text-white hover:bg-white hover:text-gray-900 font-medium rounded-lg transition-all duration-300 transform hover:scale-105"
          >
            More
          </button>
        </div>

        <!-- Social Links -->
        <div class="animate-fade-in-up" style="animation-delay: 1.2s;">
          <p class="text-white/50 text-sm mb-4">Find Me On</p>
          <div class="flex space-x-4">
            {
              socialLinks.facebook && (
                <a
                  href={socialLinks.facebook}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 bg-white/10 hover:bg-blue-600 text-white rounded-lg flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:rotate-6"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                  </svg>
                </a>
              )
            }

            {
              socialLinks.instagram && (
                <a
                  href={socialLinks.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 bg-white/10 hover:bg-gradient-to-r hover:from-purple-500 hover:to-pink-500 text-white rounded-lg flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:rotate-6"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 6.621 5.367 11.988 11.988 11.988s11.987-5.367 11.987-11.988C24.014 5.367 18.647.001 12.017.001zM8.449 16.988c-1.297 0-2.448-.49-3.328-1.291C4.203 14.811 3.5 13.49 3.5 12.017s.703-2.794 1.621-3.679c.88-.801 2.031-1.291 3.328-1.291s2.448.49 3.328 1.291c.918.885 1.621 2.206 1.621 3.679s-.703 2.794-1.621 3.679c-.88.801-2.031 1.291-3.328 1.291zm7.073 0c-1.297 0-2.448-.49-3.328-1.291-.918-.885-1.621-2.206-1.621-3.679s.703-2.794 1.621-3.679c.88-.801 2.031-1.291 3.328-1.291s2.448.49 3.328 1.291c.918.885 1.621 2.206 1.621 3.679s-.703 2.794-1.621 3.679c-.88.801-2.031 1.291-3.328 1.291z" />
                  </svg>
                </a>
              )
            }

            {
              socialLinks.whatsapp && (
                <a
                  href={socialLinks.whatsapp}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 bg-white/10 hover:bg-green-500 text-white rounded-lg flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:rotate-6"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.085" />
                  </svg>
                </a>
              )
            }

            {
              socialLinks.linkedin && (
                <a
                  href={socialLinks.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-10 h-10 bg-white/10 hover:bg-blue-700 text-white rounded-lg flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:rotate-6"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                </a>
              )
            }
          </div>
        </div>
      </div>

      <!-- Right Content - Profile Image -->
      <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative animate-fade-in-up" style="animation-delay: 0.3s;">
          <!-- Background Shape -->
          <div
            class="absolute inset-0 bg-gradient-to-br from-purple-600/30 to-green-500/30 rounded-full blur-3xl transform scale-110 animate-pulse"
          >
          </div>

          <!-- Profile Image Container -->
          <div
            class="relative w-80 h-80 md:w-96 md:h-96 lg:w-[28rem] lg:h-[28rem]"
          >
            <!-- Decorative Border -->
            <div
              class="absolute inset-0 bg-gradient-to-br from-green-400 to-purple-600 rounded-full p-1 animate-spin"
              style="animation-duration: 10s;"
            >
              <div class="w-full h-full bg-gray-900 rounded-full"></div>
            </div>

            <!-- Profile Image -->
            <div class="absolute inset-2 rounded-full overflow-hidden">
              <img
                src={profileImage}
                alt={`${name} - ${role}`}
                class="w-full h-full object-cover object-center transform hover:scale-105 transition-transform duration-500"
                loading="eager"
              />
            </div>

            <!-- Floating Elements around image -->
            <div
              class="absolute -top-4 -right-4 w-8 h-8 bg-green-400 rounded-full animate-bounce"
              style="animation-delay: 1s;"
            >
            </div>
            <div
              class="absolute -bottom-4 -left-4 w-6 h-6 bg-purple-400 rounded-full animate-ping"
              style="animation-delay: 2s;"
            >
            </div>
            <div
              class="absolute top-1/2 -left-8 w-4 h-4 border-2 border-green-400 rounded-full animate-pulse"
              style="animation-delay: 1.5s;"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <!-- <div
    class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce"
  >
    <div
      class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center"
    >
      <div class="w-1 h-3 bg-white/50 rounded-full mt-2 animate-pulse"></div>
    </div>
  </div> -->
</section>

