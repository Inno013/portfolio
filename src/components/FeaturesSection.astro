---
const features = [
  {
    title: "Lightning Fast",
    description:
      "Process thousands of tasks in seconds with our optimized AI engine. Experience unprecedented speed in workflow automation.",
    icon: "zap",
  },
  {
    title: "Enterprise Security",
    description:
      "Bank-level encryption and compliance with SOC 2, GDPR, and HIPAA standards. Your data is always protected.",
    icon: "shield",
  },
  {
    title: "Advanced Analytics",
    description:
      "Get deep insights into your workflows with real-time analytics and customizable dashboards that drive decisions.",
    icon: "bar-chart",
  },
  {
    title: "Smart Automation",
    description:
      "AI-powered automation that learns from your patterns and continuously optimizes your processes for maximum efficiency.",
    icon: "workflow",
  },
];

type IconName = "zap" | "shield" | "bar-chart" | "workflow";
const getIcon = (iconName: string) => {
  const icons: Record<IconName, string> = {
    zap: `<svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
    </svg>`,
    shield: `<svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
    </svg>`,
    "bar-chart": `<svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
    </svg>`,
    workflow: `<svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
    </svg>`,
  };
  return icons[iconName as IconName] || icons.zap;
};
---

<section id="features" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="container mx-auto">
    <div class="text-center space-y-4 mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold">
        Powerful Features for
        <span class="text-primary block">Modern Teams</span>
      </h2>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
        Everything you need to transform your workflow and boost productivity
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        features.map((feature, index) => (
          <div
            class="rounded-lg border bg-card text-card-foreground shadow-sm border-border hover:border-primary/50 transition-all duration-300 group"
          >
            <div class="flex flex-col space-y-1.5 p-6 text-center">
              <div class="mx-auto w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mb-4 group-hover:bg-primary/20 transition-colors">
                <Fragment set:html={getIcon(feature.icon)} />
              </div>
              <h3 class="text-2xl font-semibold leading-none tracking-tight text-xl">
                {feature.title}
              </h3>
            </div>
            <div class="p-6 pt-0">
              <p class="text-sm text-muted-foreground text-center leading-relaxed">
                {feature.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
