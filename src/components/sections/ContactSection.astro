---
import type { Profile } from "../../types/index";

export interface Props {
  formspreeId?: string;
  profile: Profile;
}

const { formspreeId, profile } = Astro.props;
const formAction = formspreeId ? `https://formspree.io/f/${formspreeId}` : "#";
---

<section id="contact" class="py-24 relative overflow-hidden">
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-pr-green/4 rounded-full blur-3xl pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-pr-green dark:text-pr-magenta text-sm font-semibold tracking-widest uppercase mb-3">Get in touch</p>
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Contact Me</h2>
      <div class="w-16 h-0.5 bg-gradient-to-r from-transparent via-pr-green dark:via-pr-magenta to-transparent mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 max-w-5xl mx-auto">
      <!-- Contact Info Panel -->
      <div class="lg:col-span-2 space-y-6">
        <div>
          <h3 class="text-foreground font-bold text-xl mb-2">Let's Work Together</h3>
          <p class="text-foreground/50 text-sm leading-relaxed">
            Have a project in mind or want to discuss opportunities? I'd love to hear from you.
          </p>
        </div>

        <div class="space-y-4">
          <a href={`mailto:${profile.email}`} class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-xl bg-pr-green/10 dark:bg-pr-magenta/10 border border-pr-green/20 dark:border-pr-magenta/20 flex items-center justify-center shrink-0 group-hover:bg-pr-green/20 dark:group-hover:bg-pr-magenta/20 transition-colors">
              <svg class="w-5 h-5 text-pr-green dark:text-pr-magenta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-foreground hover:text-pr-green dark:hover:text-pr-magenta text-xs uppercase tracking-wider">Email</p>
              <!-- <p class="text-foreground text-sm font-medium group-hover:text-pr-green dark:group-hover:text-pr-magenta transition-colors">{profile.email}</p> -->
            </div>
          </a>

          <a href={profile.socialLinks.linkedin} target="_blank" rel="noopener" class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-xl bg-pr-green/10 dark:bg-pr-magenta/10 border border-pr-green/20 dark:border-pr-magenta/20 flex items-center justify-center shrink-0 group-hover:bg-pr-green/20 dark:group-hover:bg-pr-magenta/20 transition-colors">
              <svg class="w-5 h-5 text-pr-green dark:text-pr-magenta" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div>
              <p class="text-foreground hover:text-pr-green dark:hover:text-pr-magenta text-xs uppercase tracking-wider">LinkedIn</p>
              <!-- <p class="text-foreground text-sm font-medium group-hover:text-pr-green dark:group-hover:text-pr-magenta transition-colors">{profile.socialLinks.linkedin}</p> -->
            </div>
          </a>

          <a href={profile.socialLinks.github} target="_blank" rel="noopener" class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-xl bg-pr-green/10 dark:bg-pr-magenta/10 border border-pr-green/20 dark:border-pr-magenta/20 flex items-center justify-center shrink-0 group-hover:bg-pr-green/20 dark:group-hover:bg-pr-magenta/20 transition-colors">
              <svg class="w-5 h-5 text-pr-green dark:text-pr-magenta" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </div>
            <div>
              <p class="text-foreground hover:text-pr-green dark:hover:text-pr-magenta text-xs uppercase tracking-wider">GitHub</p>
              <!-- <p class="text-foreground text-sm font-medium group-hover:text-pr-green dark:group-hover:text-pr-magenta transition-colors">{profile.socialLinks.github}</p> -->
            </div>
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <form
          action={formAction}
          method="POST"
          class="bg-sr-black dark:bg-pr-green/8 border border-pr-green/10 dark:border-pr-magenta/10 rounded-2xl p-6 md:p-8 space-y-5"
          id="contact-form"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-foreground/70 text-xs font-semibold uppercase tracking-wider mb-1.5">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                class="w-full bg-foreground/5 border border-pr-green/15 dark:border-pr-magenta/15 focus:border-pr-green dark:focus:border-pr-magenta text-foreground placeholder:text-foreground/30 rounded-lg px-4 py-2.5 text-sm outline-none transition-colors"
              />
            </div>
            <div>
              <label for="email" class="block text-foreground/70 text-xs font-semibold uppercase tracking-wider mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full bg-foreground/5 border border-pr-green/15 dark:border-pr-magenta/15 focus:border-pr-green dark:focus:border-pr-magenta text-foreground placeholder:text-foreground/30 rounded-lg px-4 py-2.5 text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-foreground/70 text-xs font-semibold uppercase tracking-wider mb-1.5">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              placeholder="Project inquiry..."
              class="w-full bg-foreground/5 border border-pr-green/15 dark:border-pr-magenta/15 focus:border-pr-green dark:focus:border-pr-magenta text-foreground placeholder:text-foreground/30 rounded-lg px-4 py-2.5 text-sm outline-none transition-colors"
            />
          </div>

          <div>
            <label for="message" class="block text-foreground/70 text-xs font-semibold uppercase tracking-wider mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder="Tell me about your project..."
              class="w-full bg-foreground/5 border border-pr-green/15 dark:border-pr-magenta/15 focus:border-pr-green dark:focus:border-pr-magenta text-foreground placeholder:text-foreground/30 rounded-lg px-4 py-2.5 text-sm outline-none transition-colors resize-none"
            ></textarea>
          </div>

          <div class="flex items-center justify-between gap-4">
            <button
              type="submit"
              class="bg-pr-green hover:bg-sr-green text-pr-black font-semibold rounded-lg px-6 py-2.5 text-sm transition-all duration-300 hover:shadow-lg hover:shadow-pr-green/20 dark:hover:shadow-pr-magenta/20 flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
              Send Message
            </button>
            <!-- <p class="text-foreground/30 text-xs">Powered by Formspree</p> -->
          </div>

          <!-- Success/Error messages -->
          <div id="form-success" class="hidden text-pr-green dark:text-pr-magenta text-sm font-medium text-center py-2">
            Message sent successfully! I'll get back to you soon.
          </div>
          <div id="form-error" class="hidden text-red-400 text-sm font-medium text-center py-2">
            Something went wrong. Please try again or email me directly.
          </div>
        </form>

        <script>
          const form = document.getElementById("contact-form") as HTMLFormElement | null;
          const successMsg = document.getElementById("form-success");
          const errorMsg = document.getElementById("form-error");

          form?.addEventListener("submit", async (e) => {
            const actionUrl = form.getAttribute("action");
            if (!actionUrl || actionUrl === "#") return;
            e.preventDefault();
            const data = new FormData(form);
            try {
              const res = await fetch(actionUrl, { method: "POST", body: data, headers: { Accept: "application/json" } });
              if (res.ok) {
                form.reset();
                successMsg?.classList.remove("hidden");
                errorMsg?.classList.add("hidden");
              } else {
                errorMsg?.classList.remove("hidden");
                successMsg?.classList.add("hidden");
              }
            } catch {
              errorMsg?.classList.remove("hidden");
              successMsg?.classList.add("hidden");
            }
          });
        </script>
      </div>
    </div>
  </div>
</section>
