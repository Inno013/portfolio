---
import type { Experience, Education } from "../../types/index";

export interface Props {
  experiences: Experience[];
  education: Education[];
}

const { experiences, education } = Astro.props;
---

<section id="about" class="py-24 relative overflow-hidden">
  <div class="absolute top-1/2 left-0 w-80 h-80 bg-pr-green/4 rounded-full blur-3xl pointer-events-none"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-pr-green dark:text-pr-magenta text-sm font-semibold tracking-widest uppercase mb-3">My journey</p>
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Career & Education</h2>
      <div class="w-16 h-0.5 bg-gradient-to-r from-transparent via-pr-green dark:via-pr-magenta to-transparent mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Work Experience -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-pr-green/10 dark:bg-pr-magenta/10 border border-pr-green/20 dark:border-pr-magenta/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-pr-green dark:text-pr-magenta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0H8m8 0a2 2 0 012 2v6a2 2 0 01-2 2H8a2 2 0 01-2-2V8a2 2 0 012-2" />
            </svg>
          </div>
          <h3 class="text-foreground font-bold text-xl">Work Experience</h3>
        </div>

        <div class="relative">
          <div class="absolute left-3.5 top-0 bottom-0 w-px bg-gradient-to-b from-pr-green/50 dark:from-pr-magenta/50 via-pr-green/20 dark:via-pr-magenta/20 to-transparent"></div>

          <div class="space-y-8">
            {experiences.map((exp) => (
              <div class="relative pl-10">
                <div class={`absolute left-0 top-1.5 w-7 h-7 rounded-full border-2 flex items-center justify-center transition-all duration-300 ${exp.isCurrent ? "bg-pr-green dark:bg-pr-magenta border-pr-green dark:border-pr-magenta shadow-lg shadow-pr-green/40 dark:shadow-pr-magenta/40" : "bg-sr-black dark:bg-pr-green/10 border-pr-green/40 dark:border-pr-magenta/40"}`}>
                  {exp.isCurrent ? (
                    <div class="w-2 h-2 bg-pr-black rounded-full"></div>
                  ) : (
                    <div class="w-1.5 h-1.5 bg-pr-green/60 dark:bg-pr-magenta/60 rounded-full"></div>
                  )}
                </div>

                <div class="bg-sr-black dark:bg-pr-green/8 border border-pr-green/10 dark:border-pr-magenta/10 hover:border-pr-green/25 dark:hover:border-pr-magenta/25 rounded-xl p-5 transition-all duration-300 hover:shadow-lg hover:shadow-pr-green/5">
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <div>
                      <h4 class="text-foreground font-semibold">{exp.role}</h4>
                      <div class="flex items-center gap-2 mt-0.5">
                        <span class="text-pr-green dark:text-pr-magenta text-sm font-medium">{exp.company}</span>
                        {exp.type && (
                          <span class="text-xs text-foreground/50 border border-foreground/10 px-1.5 py-0.5 rounded">{exp.type}</span>
                        )}
                      </div>
                    </div>
                    {exp.isCurrent && (
                      <span class="text-xs bg-pr-green/15 dark:bg-pr-magenta/15 text-pr-green dark:text-pr-magenta border border-pr-green/30 dark:border-pr-magenta/30 px-2 py-0.5 rounded-full shrink-0 font-medium">Current</span>
                    )}
                  </div>
                  <p class="text-foreground/50 text-xs font-medium mb-3">
                    {exp.startDate} — {exp.endDate}
                  </p>
                  {exp.description && (
                    <p class="text-foreground/60 text-sm leading-relaxed">{exp.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Education -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-pr-green/10 dark:bg-pr-magenta/10 border border-pr-green/20 dark:border-pr-magenta/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-pr-green dark:text-pr-magenta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
            </svg>
          </div>
          <h3 class="text-foreground font-bold text-xl">Education</h3>
        </div>

        <div class="relative">
          <div class="absolute left-3.5 top-0 bottom-0 w-px bg-gradient-to-b from-pr-green/50 dark:from-pr-magenta/50 via-pr-green/20 dark:via-pr-magenta/20 to-transparent"></div>

          <div class="space-y-8">
            {education.map((edu) => (
              <div class="relative pl-10">
                <div class="absolute left-0 top-1.5 w-7 h-7 rounded-full border-2 bg-sr-black dark:bg-pr-green/10 border-pr-green/40 dark:border-pr-magenta/40 flex items-center justify-center">
                  <div class="w-1.5 h-1.5 bg-pr-green/60 dark:bg-pr-magenta/60 rounded-full"></div>
                </div>

                <div class="bg-sr-black dark:bg-pr-green/8 border border-pr-green/10 dark:border-pr-magenta/10 hover:border-pr-green/25 dark:hover:border-pr-magenta/25 rounded-xl p-5 transition-all duration-300 hover:shadow-lg hover:shadow-pr-green/5">
                  <h4 class="text-foreground font-semibold">{edu.institution}</h4>
                  <p class="text-pr-green dark:text-pr-magenta text-sm font-medium mt-0.5">
                    {edu.degree}{edu.field ? ` — ${edu.field}` : ""}
                  </p>
                  <p class="text-foreground/50 text-xs font-medium mb-3">
                    {edu.startDate} — {edu.endDate}
                    {edu.gpa && <span class="ml-2 text-foreground/40">GPA: {edu.gpa}</span>}
                  </p>
                  {edu.description && (
                    <p class="text-foreground/60 text-sm leading-relaxed">{edu.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
