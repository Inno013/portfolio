---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import HeroSection from "../components/HeroSection.astro";
import SkillsSection from "../components/sections/SkillsSection.astro";
import ProjectsSection from "../components/sections/ProjectsSection.astro";
import CareerEducationSection from "../components/sections/CareerEducationSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import {
  getProfile,
  getSkills,
  getProjects,
  getExperiences,
  getEducation,
} from "../lib/notion";

// Fetch all data at build time (SSG)
const [profile, skills, projects, experiences, education] = await Promise.all([
  getProfile(),
  getSkills(),
  getProjects(),
  getExperiences(),
  getEducation(),
]);

const formspreeId = import.meta.env.FORMSPREE_ID ?? "";
---

<Layout
  title={`${profile.name} — ${profile.role}`}
  description={profile.description.slice(0, 160)}
>
  <Header />
  <main>
    <HeroSection profile={profile} />
    <SkillsSection skills={skills} />
    <ProjectsSection projects={projects} />
    <CareerEducationSection experiences={experiences} education={education} />
    <ContactSection profile={profile} formspreeId={formspreeId} />
  </main>

  <!-- Footer -->
  <footer class="border-t border-pr-green/10 py-8 text-center">
    <p class="text-white/40 dark:text-black/50 text-sm">
      © {new Date().getFullYear()} <span class="text-pr-green dark:text-pr-magenta">{profile.name}</span>.
    </p>
    <p class="text-white/60 dark:text-black/70 text-sm">
      Designed & developed with passion.
    </p>
  </footer>
</Layout>
